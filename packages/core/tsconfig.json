{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": [
            "ES2020"
        ],
        "strict": true,
        "esModuleInterop": false,
        "skipLibCheck": true,
        "types": [
            "vitest/globals",
            "node"
        ]
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}