{
    "name": "@data-generators/core",
    "version": "0.3.0",
    "type": "module",
    "engines": {
        "node": ">=24.0.0"
    },
    "scripts": {
        "build": "tsup",
        "test": "vitest run",
        "test:release": "tsup && vitest run --config vitest.config.release.ts",
        "typecheck": "tsc --noEmit"
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "files": [
        "dist",
        "package.json"
    ],
    "dependencies": {
        "ts-toolbelt": "^9.6.0"
    },
    "devDependencies": {
        "typescript": "^5.9.3",
        "tsup": "^8.5.1",
        "vitest": "^4.0.18",
        "@types/node": "^24.0.0"
    }
}
